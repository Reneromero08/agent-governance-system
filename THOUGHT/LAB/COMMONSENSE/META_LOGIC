    "explains": {"type": "array", "items": {"type": "string"},
      "description": "Observation IDs this hypothesis claims to explain"},
    "competitors": {"type": "array", "items": {"type": "string"},
      "description": "IDs of competing hypotheses"},
    "score": {"type": "object",
