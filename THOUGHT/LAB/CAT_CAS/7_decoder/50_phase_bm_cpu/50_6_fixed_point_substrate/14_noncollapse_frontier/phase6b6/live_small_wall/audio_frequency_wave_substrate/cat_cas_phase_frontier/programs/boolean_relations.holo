CATCAS_PHASE_PROGRAM 1
REGISTERS 8

# Boolean inputs occupy the 0/1 subset of F3 phase labels.
SET 0 1
SET 1 1
SET 2 1
SET 6 1

# NOT(a) = 1 - a = 1 + 2a in F3.
ADD 0 2
ADD 0 2

# AND(a,b) = ab.
MULADD 0 1 3

# XOR(a,b) = a + b + ab for a,b in {0,1}.
ADD 0 4
ADD 1 4
MULADD 0 1 4

# OR(a,b) = a + b - ab = a + b + 2ab.
ADD 0 5
ADD 1 5
MULADD 0 1 5
MULADD 0 1 5

# NAND(a,b) = 1 - ab = 1 + 2ab.
MULADD 0 1 6
MULADD 0 1 6

# Keep one routed copy as a reusable relation.
ADD 6 7
END
