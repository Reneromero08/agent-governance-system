CATCAS_PHASE_PROGRAM 1
REGISTERS 8

# Public boundary load. Unspecified registers start at phase symbol zero.
SET 0 2
SET 1 1

# sum = a + b mod 3; product = a * b mod 3
ADD 0 2
ADD 1 2
MULADD 0 1 3

# Further reversible phase routing makes this a nontrivial carrier traversal.
ROT 4 2
ADD 2 5
MULADD 3 4 6
SWAP 5 7
END
