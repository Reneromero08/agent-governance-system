{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "CAT_CAS_PHASE6B6_SNAPSHOT_IDENTITY_V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "expected_commit",
    "expected_tree",
    "observed_tree",
    "file_sha256_inventory",
    "qualification_contract_digest",
    "phase6b6_source_package_identity",
    "v2_source_identity",
    "generated_final_campaign_sessions_present",
    "authority"
  ],
  "properties": {
    "schema_id": { "const": "CAT_CAS_PHASE6B6_SNAPSHOT_IDENTITY_V1" },
    "expected_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "expected_tree": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "observed_tree": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "file_sha256_inventory": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
    },
    "qualification_contract_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "phase6b6_source_package_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root"],
      "properties": {
        "root": { "const": "phase6b6" }
      }
    },
    "v2_source_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string" },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "generated_final_campaign_sessions_present": { "const": false },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase6b6_entry_approved",
        "phase6b6_entered",
        "schema_id",
        "architecture_review",
        "software_entry_review",
        "project_owner_decision",
        "implementation_authorized",
        "software_qualification_authorized",
        "non_hardware_target_qualification_authorized",
        "hardware_ran",
        "authorization_artifact_created",
        "calibration_authorized",
        "scientific_acquisition_authorized",
        "restoration_authorized",
        "target_coupling_authorized",
        "small_wall_authorized",
        "automatic_retry"
      ],
      "properties": {
        "phase6b6_entry_approved": { "const": true },
        "phase6b6_entered": { "const": true },
        "schema_id": { "type": "string" },
        "architecture_review": { "type": "integer" },
        "software_entry_review": { "type": "integer" },
        "project_owner_decision": { "type": "string" },
        "implementation_authorized": { "const": true },
        "software_qualification_authorized": { "const": true },
        "non_hardware_target_qualification_authorized": { "const": true },
        "hardware_ran": { "const": false },
        "authorization_artifact_created": { "const": false },
        "calibration_authorized": { "const": false },
        "scientific_acquisition_authorized": { "const": false },
        "restoration_authorized": { "const": false },
        "target_coupling_authorized": { "const": false },
        "small_wall_authorized": { "const": false },
        "automatic_retry": { "const": false }
      }
    }
  }
}
