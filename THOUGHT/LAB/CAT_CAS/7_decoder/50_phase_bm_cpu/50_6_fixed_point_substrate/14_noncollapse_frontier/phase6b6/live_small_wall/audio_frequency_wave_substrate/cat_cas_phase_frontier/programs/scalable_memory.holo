CATCAS_PHASE_PROGRAM 1
REGISTERS 65536

# Exercise distant regions of a two-megabyte twin-rail phase carrier.
SET 0 1
SET 8191 2
SET 16384 1
SET 32767 2
SET 49152 1
SET 65535 2

ADD 0 8191
MULADD 8191 16384 32767
ROT 49152 2
ADD 32767 65535
MULADD 0 65535 49152
SWAP 16384 49152
ADD 8191 32767
MULADD 32767 49152 65535
END
