    "path_mode_blob_inventory",
    "expected_inventory_sha256",
    "expected_phase6b6_subtree_inventory_sha256",
    "expected_scoped_tree"
  ],
  "properties": {
    "schema_id": { "const": "CAT_CAS_PHASE6B6_TRUSTED_SNAPSHOT_BINDING_V1" },
    "snapshot_subject_kind": { "const": "PHASE6B6_SOFTWARE_IMPLEMENTATION_ONLY" },
    "snapshot_subject_commit": { "const": "d351a62f4f211589d57359d872734757b6e280d9" },
    "snapshot_subject_tree": { "const": "1a927b20cb2d712a7220a823621c8fc83cbc984d" },
    "snapshot_scope": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "prefixItems": [
        { "const": "THOUGHT/LAB/CAT_CAS/7_decoder/50_phase_bm_cpu/50_6_fixed_point_substrate/14_noncollapse_frontier/phase6b6" },
        { "const": "THOUGHT/LAB/CAT_CAS/7_decoder/50_phase_bm_cpu/50_6_fixed_point_substrate/14_noncollapse_frontier/holo_runtime_v2/combined_pdn_hardware.c" }
      ]
    },
    "qualification_harness_source_equals_snapshot_subject": { "const": false },
    "tracked_file_count": { "type": "integer", "minimum": 1 },
    "phase6b6_tracked_file_count": { "type": "integer", "minimum": 1 },
    "path_mode_blob_inventory": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/path_mode_inventory_entry" }
    },
    "expected_inventory_sha256": { "const": "e47dea4c3467835a425d9d553803da48f672a8799970db4fc9b83e98596f50d8" },
