{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "CAT_CAS_PHASE6B6_TRUSTED_SNAPSHOT_BINDING_V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "snapshot_subject_kind",
    "snapshot_subject_commit",
    "snapshot_subject_tree",
    "snapshot_scope",
    "qualification_harness_source_equals_snapshot_subject",
    "tracked_file_count",
    "phase6b6_tracked_file_count",
    "path_mode_blob_inventory",
    "expected_inventory_sha256",
    "expected_phase6b6_subtree_inventory_sha256",
    "expected_scoped_tree"
  ],
  "properties": {
    "schema_id": { "const": "CAT_CAS_PHASE6B6_TRUSTED_SNAPSHOT_BINDING_V1" },
    "snapshot_subject_kind": { "const": "PHASE6B6_SOFTWARE_IMPLEMENTATION_ONLY" },
    "snapshot_subject_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "snapshot_subject_tree": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "snapshot_scope": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string" }
    },
    "qualification_harness_source_equals_snapshot_subject": { "const": false },
    "tracked_file_count": { "type": "integer", "minimum": 1 },
    "phase6b6_tracked_file_count": { "type": "integer", "minimum": 1 },
    "path_mode_blob_inventory": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "mode", "git_object_type", "git_object_sha", "sha256", "size"],
        "properties": {
          "path": { "type": "string" },
          "mode": { "enum": ["100644", "100755"] },
          "git_object_type": { "const": "blob" },
          "git_object_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "size": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "expected_inventory_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "expected_phase6b6_subtree_inventory_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "expected_scoped_tree": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
  }
}
