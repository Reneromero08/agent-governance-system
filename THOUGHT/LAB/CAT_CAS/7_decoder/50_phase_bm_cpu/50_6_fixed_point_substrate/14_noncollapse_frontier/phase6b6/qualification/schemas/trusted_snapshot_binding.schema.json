    "expected_scoped_tree": { "const": "408ee35257417898a992510b0f260602117a15af" }
  },
  "$defs": {
    "path_mode_inventory_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "mode", "git_object_type", "git_object_sha", "sha256", "size"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "mode": { "enum": ["100644", "100755"] },
        "git_object_type": { "const": "blob" },
        "git_object_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "size": { "type": "integer", "minimum": 0 }
