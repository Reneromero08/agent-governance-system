        "export_version": {"type": "string"},
        "firmware": {"type": "string"},
        "frame_interleave": {"type": "string"},
        "gain": {"items": {"$ref": "#/$defs/finite_decimal"}, "maxItems": 4, "minItems": 4, "type": "array"},
        "header_bytes": {"minimum": 0, "type": "integer"},
        "instrument_model": {"type": "string"},
        "instrument_serial": {"type": "string"},
        "offset": {"items": {"$ref": "#/$defs/finite_decimal"}, "maxItems": 4, "minItems": 4, "type": "array"},
        "padding_bytes": {"minimum": 0, "type": "integer"},
        "parser_sha256": {"$ref": "#/$defs/sha256"},
        "precommand_count": {"const": 1101000},
        "record_type": {"const": "raw_descriptor"},
        "run_id": {"$ref": "#/$defs/run_id"},
        "sample_count": {"const": 3101000},
        "sample_rate_hz": {"const": 1000000},
        "schema_version": {"const": "p0-evidence-v1"},
