        "sequence_number": {"maximum": 3, "minimum": 2, "type": "integer"},
        "signature_algorithm": {"const": "Ed25519"},
        "signature_base64": {"maxLength": 88, "minLength": 88, "pattern": "^[A-Za-z0-9+/]{86}==$", "type": "string"},
