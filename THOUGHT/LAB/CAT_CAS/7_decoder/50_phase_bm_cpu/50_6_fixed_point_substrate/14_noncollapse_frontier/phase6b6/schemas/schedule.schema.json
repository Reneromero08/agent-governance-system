{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "CAT_CAS_PHASE6B6_EXPLICIT_SLOT_SCHEDULE_V1",
  "type": "object",
  "required": ["schema_id", "contract", "sessions", "session_count", "total_slots", "schedule_sha256"],
  "properties": {
    "schema_id": { "const": "CAT_CAS_PHASE6B6_EXPLICIT_SLOT_SCHEDULE_V1" },
    "session_count": { "const": 12 },
    "total_slots": { "const": 10368 },
    "contract": { "type": "object" },
    "sessions": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": { "$ref": "#/$defs/session" }
    },
    "schedule_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  },
  "additionalProperties": false,
  "$defs": {
    "session": {
      "type": "object",
      "required": ["session_index", "reboot_block", "route", "sender_core", "receiver_core", "split", "session_chronology", "order_family_sequence", "slots", "slot_count"],
      "properties": {
        "session_index": { "type": "integer", "minimum": 0, "maximum": 11 },
        "reboot_block": { "enum": ["b0", "b1", "b2", "b3", "b4", "b5"] },
        "route": { "enum": ["v4s5", "v2s3"] },
        "sender_core": { "enum": [2, 4] },
        "receiver_core": { "enum": [3, 5] },
        "split": { "enum": ["train", "validation", "test"] },
        "session_chronology": { "type": "integer", "minimum": 0, "maximum": 11 },
        "order_family_sequence": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": { "enum": ["FWD", "REV", "RND1", "RND2", "ORDER_LABEL_SHAM"] }
        },
        "slots": {
          "type": "array",
          "minItems": 864,
          "maxItems": 864,
          "items": { "$ref": "#/$defs/slot" }
        },
        "slot_count": { "const": 864 }
      },
      "additionalProperties": false
    },
    "slot": {
      "type": "object",
      "required": ["session_index", "slot_index", "stage", "packet_id", "requested_start_tick", "requested_end_tick", "nominal_samples", "declared", "executed"],
      "properties": {
        "session_index": { "type": "integer", "minimum": 0, "maximum": 11 },
        "slot_index": { "type": "integer", "minimum": 0, "maximum": 863 },
        "stage": { "enum": ["preamble", "prepared_order", "trajectory", "tail_drift"] },
        "packet_id": { "type": ["string", "null"] },
        "requested_start_tick": { "type": "integer", "minimum": 0, "maximum": 863 },
        "requested_end_tick": { "type": "integer", "minimum": 1, "maximum": 864 },
        "nominal_samples": { "const": 4000 },
        "declared": { "$ref": "#/$defs/declared" },
        "executed": { "$ref": "#/$defs/executed" }
      },
      "additionalProperties": false
    },
    "declared": {
      "type": "object",
      "required": ["declared_mode", "declared_amplitude_level", "declared_phase_action", "declared_physical_tone_index", "declared_order_family", "declared_order_position", "analysis_tone_index"],
      "properties": {
        "declared_mode": { "type": "string" },
        "declared_amplitude_level": { "type": ["integer", "null"], "enum": [0, 1, 2, null] },
        "declared_phase_action": { "enum": ["none", "0", "pi", "pi/2", "-pi/2", null] },
        "declared_physical_tone_index": { "type": ["integer", "null"], "minimum": 0, "maximum": 11 },
        "declared_order_family": { "type": ["string", "null"], "enum": ["FWD", "REV", "RND1", "RND2", "ORDER_LABEL_SHAM", null] },
        "declared_order_position": { "type": ["integer", "null"], "minimum": 0, "maximum": 11 },
        "analysis_tone_index": { "type": ["integer", "null"], "minimum": 0, "maximum": 11 }
      },
      "additionalProperties": false
    },
    "executed": {
      "type": "object",
      "required": ["drive_on", "executed_mode", "executed_v2_mode", "amplitude_level", "phase_action", "physical_tone_index", "analysis_tone_index", "tone_execution_order_position", "executed_order_family", "executed_order_position", "executed_codeword_signs", "codeword_source_index", "codeword_sign", "sign", "sender_epoch_id"],
      "properties": {
        "drive_on": { "type": "boolean" },
        "executed_mode": { "type": "string" },
        "executed_v2_mode": { "enum": ["basis", null] },
        "amplitude_level": { "type": ["integer", "null"], "enum": [0, 1, 2, null] },
        "phase_action": { "enum": ["0", "pi", "pi/2", "-pi/2", null] },
        "physical_tone_index": { "type": ["integer", "null"], "minimum": 0, "maximum": 11 },
        "analysis_tone_index": { "type": ["integer", "null"], "minimum": 0, "maximum": 11 },
        "tone_execution_order_position": { "type": ["integer", "null"], "minimum": 0, "maximum": 11 },
        "executed_order_family": { "type": ["string", "null"], "enum": ["FWD", "REV", "RND1", "RND2", "ORDER_LABEL_SHAM", null] },
        "executed_order_position": { "type": ["integer", "null"], "minimum": 0, "maximum": 11 },
        "executed_codeword_signs": {
          "anyOf": [
            { "type": "null" },
            { "type": "array", "minItems": 12, "maxItems": 12, "items": { "enum": [-1, 1] } }
          ]
        },
        "codeword_source_index": { "type": ["integer", "null"], "minimum": 0, "maximum": 11 },
        "codeword_sign": { "type": ["integer", "null"], "enum": [-1, 1, null] },
        "sign": { "type": ["integer", "null"], "enum": [-1, 1, null] },
        "sender_epoch_id": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  }
}
