#!/bin/sh
set -e

# ============================================================
# AGENT POLICY: Commit Ceremony (AGENTS.md Section 10)
# ============================================================
# Every commit requires explicit, per-instance human approval.
# If you are committing without explicit instructions, STOP.
# Ask the user: "Ready for the Chunked Commit Ceremony?"
# This is NOT a gate for humans -- it is a reminder for agents.
# ============================================================
echo "[PRE-COMMIT] Agent Policy: Verify explicit commit approval."
echo "[PRE-COMMIT] If unclear, see AGENTS.md Section 10."

# Cross-platform Python detection
if python3 --version >/dev/null 2>&1; then
    PYTHON_CMD="python3"
elif python --version >/dev/null 2>&1; then
    PYTHON_CMD="python"
else
    echo "[PRE-COMMIT] ERROR: No Python found"
    exit 1
fi

# Block private key commits (Crypto Safe)
echo "[PRE-COMMIT] Checking for private keys..."
if git diff --cached --name-only | grep -E '\.key$' | grep -v '\.pub\.key$'; then
    echo ""
    echo "[PRE-COMMIT] ERROR: Private key file staged for commit!"
    echo "             Signing keys must NEVER be committed to the repository."
    echo ""
    echo "  Unstage with: git reset HEAD <file>.key"
    echo ""
    exit 1
fi

echo "[PRE-COMMIT] Running canon governance check..."
node CAPABILITY/TOOLS/check-canon-governance.js

echo "[PRE-COMMIT] Running INBOX policy check..."
$PYTHON_CMD CAPABILITY/SKILLS/inbox/inbox-report-writer/check_inbox_policy.py

echo "[PRE-COMMIT] Running CAT_CAS manifesto critic..."
$PYTHON_CMD CAPABILITY/TOOLS/governance/critic.py
CRITIC_EXIT=$?
if [ $CRITIC_EXIT -ne 0 ]; then
    echo ""
    echo "[PRE-COMMIT] CAT_CAS manifesto violations detected. Commit blocked."
    echo "             Fix violations or request Lead Physicist waiver."
    echo "             See: THOUGHT/LAB/CAT_CAS/REPORTS/VIOLATIONS/ROADMAP.md"
    exit 1
fi

echo "[PRE-COMMIT] OK"
