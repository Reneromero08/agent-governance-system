#!/bin/sh
# Pre-push hook: require a verification receipt for the commit actually pushed.
set -e

if [ -x ".venv/Scripts/python.exe" ]; then
    PYTHON_CMD=".venv/Scripts/python.exe"
elif [ -x ".venv/bin/python" ]; then
    PYTHON_CMD=".venv/bin/python"
elif python3 --version >/dev/null 2>&1; then
    PYTHON_CMD="python3"
elif python --version >/dev/null 2>&1; then
    PYTHON_CMD="python"
else
    echo "[PRE-PUSH] ERROR: No Python found"
    exit 1
fi

ZERO_SHA="0000000000000000000000000000000000000000"
TOKEN_FILE="LAW/CONTRACTS/_runs/ALLOW_PUSH.token"
REFS_FILE="LAW/CONTRACTS/_runs/_tmp/pre-push-refs.$$"
GUARD="CAPABILITY/TOOLS/utilities/pre_push_guard.py"
mkdir -p "$(dirname "$REFS_FILE")"
cat > "$REFS_FILE"
trap 'rm -f "$REFS_FILE"' EXIT HUP INT TERM

while read local_ref local_sha remote_ref remote_sha; do
    if [ "$local_sha" != "$ZERO_SHA" ] && echo "$remote_ref" | grep -qE '^refs/tags/v[0-9]'; then
        TAG_NAME=$(echo "$remote_ref" | sed 's|refs/tags/||')
        SEAL_DIR="NAVIGATION/PROOFS/RELEASES/$TAG_NAME"
        echo "[PRE-PUSH] Release tag detected: $TAG_NAME"
        if [ ! -f "$SEAL_DIR/RELEASE_MANIFEST.json" ]; then
            echo "[PRE-PUSH] ERROR: release tag has no seal at $SEAL_DIR"
            exit 1
        fi
        if ! "$PYTHON_CMD" -m CAPABILITY.TOOLS.catalytic.verify_release --repo-dir . --version "$TAG_NAME"; then
            echo "[PRE-PUSH] ERROR: release seal verification failed"
            exit 1
        fi
    fi
done < "$REFS_FILE"

# No-op pushes and deletion-only pushes introduce no new commit content.
if [ ! -s "$REFS_FILE" ]; then
    echo "[PRE-PUSH] No ref updates; verification receipt not required."
    exit 0
fi
if awk -v zero="$ZERO_SHA" 'NF && $2 != zero { found=1 } END { exit found ? 1 : 0 }' "$REFS_FILE"; then
    echo "[PRE-PUSH] Deletion-only push; verification receipt not required."
    exit 0
fi

if [ ! -f "$TOKEN_FILE" ]; then
    echo ""
    echo "PUSH BLOCKED: no verification receipt"
    echo "Run: python CAPABILITY/TOOLS/utilities/ci_local_gate.py --full"
    echo "For release/nightly depth: add --exhaustive"
    exit 1
fi

set +e
"$PYTHON_CMD" "$GUARD" --refs-file "$REFS_FILE" --token-file "$TOKEN_FILE"
GUARD_RC=$?
set -e

if [ "$GUARD_RC" -eq 2 ]; then
    echo "[PRE-PUSH] Legacy/manual token detected; running the canonical full gate."
    "$PYTHON_CMD" CAPABILITY/TOOLS/utilities/ci_local_gate.py --full
    "$PYTHON_CMD" "$GUARD" --refs-file "$REFS_FILE" --token-file "$TOKEN_FILE"
elif [ "$GUARD_RC" -ne 0 ]; then
    echo "Re-run: python CAPABILITY/TOOLS/utilities/ci_local_gate.py --full"
    exit "$GUARD_RC"
fi

if ! git diff --cached --quiet; then
    echo "PUSH BLOCKED: staged changes are not committed"
    exit 1
fi

echo "[PRE-PUSH] Push approved."
echo "[PRE-PUSH] Receipt retained. A new commit invalidates it automatically."
exit 0
