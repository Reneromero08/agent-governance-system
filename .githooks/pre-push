#!/bin/sh
# Pre-push hook: require a HEAD-bound verification receipt.
set -e

if python3 --version >/dev/null 2>&1; then
    PYTHON_CMD="python3"
elif python --version >/dev/null 2>&1; then
    PYTHON_CMD="python"
else
    echo "[PRE-PUSH] ERROR: No Python found"
    exit 1
fi

TOKEN_FILE="LAW/CONTRACTS/_runs/ALLOW_PUSH.token"
REFS_FILE="LAW/CONTRACTS/_runs/_tmp/pre-push-refs.$$"
mkdir -p "$(dirname "$REFS_FILE")"
cat > "$REFS_FILE"
trap 'rm -f "$REFS_FILE"' EXIT HUP INT TERM

while read local_ref local_sha remote_ref remote_sha; do
    if echo "$remote_ref" | grep -qE '^refs/tags/v[0-9]'; then
        TAG_NAME=$(echo "$remote_ref" | sed 's|refs/tags/||')
        SEAL_DIR="NAVIGATION/PROOFS/RELEASES/$TAG_NAME"
        echo "[PRE-PUSH] Release tag detected: $TAG_NAME"
        if [ ! -f "$SEAL_DIR/RELEASE_MANIFEST.json" ]; then
            echo "[PRE-PUSH] ERROR: release tag has no seal at $SEAL_DIR"
            exit 1
        fi
        if ! "$PYTHON_CMD" -m CAPABILITY.TOOLS.catalytic.verify_release --repo-dir . --version "$TAG_NAME"; then
            echo "[PRE-PUSH] ERROR: release seal verification failed"
            exit 1
        fi
    fi
done < "$REFS_FILE"

if [ ! -f "$TOKEN_FILE" ]; then
    echo ""
    echo "PUSH BLOCKED: no HEAD-bound verification receipt"
    echo "Run: python CAPABILITY/TOOLS/utilities/ci_local_gate.py --full"
    echo "For release/nightly depth: add --exhaustive"
    exit 1
fi

HEAD=$(git rev-parse HEAD 2>/dev/null || true)
TOK_HEAD=$($PYTHON_CMD - "$TOKEN_FILE" <<'PY'
import json, sys
try:
    payload = json.load(open(sys.argv[1], encoding="utf-8"))
except Exception:
    print("")
else:
    print(payload.get("head", "") if payload.get("type") == "CI_OK" else "")
PY
)

if [ -z "$TOK_HEAD" ]; then
    echo "[PRE-PUSH] Legacy/manual token detected; running the canonical full gate."
    "$PYTHON_CMD" CAPABILITY/TOOLS/utilities/ci_local_gate.py --full
    TOK_HEAD=$($PYTHON_CMD - "$TOKEN_FILE" <<'PY'
import json, sys
payload = json.load(open(sys.argv[1], encoding="utf-8"))
print(payload.get("head", ""))
PY
)
fi

if [ -z "$HEAD" ] || [ "$TOK_HEAD" != "$HEAD" ]; then
    echo ""
    echo "PUSH BLOCKED: verification receipt does not match current HEAD"
    echo "  receipt: $TOK_HEAD"
    echo "  current: $HEAD"
    echo "Re-run: python CAPABILITY/TOOLS/utilities/ci_local_gate.py --full"
    exit 1
fi

if ! git diff --cached --quiet; then
    echo "PUSH BLOCKED: staged changes are not committed"
    exit 1
fi

echo "[PRE-PUSH] Push approved for HEAD $HEAD"
echo "[PRE-PUSH] Receipt retained. A new commit invalidates it automatically."
exit 0
